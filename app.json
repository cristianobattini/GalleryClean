{
  "expo": {
    "name": "GalleryClean",
    "slug": "gallery-clean",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.galleryclean.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "GalleryClean needs access to your photo library to help you clean it up.",
        "NSPhotoLibraryAddUsageDescription": "GalleryClean needs access to save photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "package": "com.galleryclean.app",
      "permissions": [
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Allow GalleryClean to access your photos.",
          "savePhotosPermission": "Allow GalleryClean to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
